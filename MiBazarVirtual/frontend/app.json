{
  "expo": {
    "name": "MiBazarVirtual",
    "slug": "mibazarvirtual",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#1B4332"
    },
    "android": {
      "package": "com.services",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#1B4332"
      }
    },
    "androidStatusBar": {
      "backgroundColor": "#00000000",
      "translucent": true,
      "barStyle": "dark-content"
    },
    "ios": {
      "bundleIdentifier": "com.serviceaccount",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "UIStatusBarStyle": "UIStatusBarStyleDarkContent",
        "NSCameraUsageDescription": "MiBazarVirtual usa la camara para tomar fotos de tus productos.",
        "NSPhotoLibraryUsageDescription": "MiBazarVirtual usa tu galeria para seleccionar fotos de productos.",
        "NSUserNotificationUsageDescription": "MiBazarVirtual usa notificaciones para avisarte sobre pedidos y mensajes."
      }
    },
    "notification": {
      "icon": "./assets/icon.png",
      "color": "#1B4332",
      "androidMode": "default",
      "androidCollapsedTitle": "MiBazarVirtual"
    },
    "plugins": [
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "MiBazarVirtual usa tu galeria para seleccionar fotos de productos.",
          "cameraPermission": "MiBazarVirtual usa la camara para tomar fotos de tus productos."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "firebaseProjectId": "mi-bazar-eee41",
      "firebaseSenderId": "727983217175",
      "eas": {
        "projectId": "3e809ce7-3313-42d2-8125-5ed677fa2572"
      }
    }
  }
}
